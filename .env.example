# Required
OPENAI_API_KEY=sk-...
MODAL_TOKEN_ID=...
MODAL_TOKEN_SECRET=...

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/clinical_trials
REDIS_URL=redis://localhost:6379

# Optional
HF_TOKEN=...
LANGCHAIN_API_KEY=...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=clinical-trial-search

# Model config
BASE_MODEL=BioMistral/BioMistral-7B
LORA_ADAPTER_PATH=./outputs/qlora-biomistral/adapter
